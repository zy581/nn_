<mujoco model="humanoid_rl">
  <compiler angle="radian" inertiafromgeom="true"/>
  <option gravity="0 0 -9.81" timestep="0.005"/>

  <asset>
    <material name="body" rgba="0.7 0.7 0.7 1"/>
    <material name="floor" rgba="0.3 0.3 0.3 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 4"/>
    <camera name="cam" pos="0 -3.5 1.2" xyaxes="1 0 0 0 0.6 1"/>
    <geom name="ground" type="plane" size="4 4 0.1" material="floor" friction="2.0 0.5 0.5"/>

    <!-- 根节点 -->
    <body name="torso" pos="0 0 1.2">
      <freejoint/>
      <geom type="capsule" size="0.07 0.15" mass="6" material="body"/>

      <!-- 头部 -->
      <body name="head" pos="0 0 0.25">
        <geom type="sphere" size="0.1" mass="1" material="body"/>
        <joint name="neck" type="hinge" axis="0 0 1" range="-0.5 0.5" damping="0.5"/>
      </body>

      <!-- 左臂 -->
      <body name="l_shoulder" pos="-0.12 0 0">
        <joint name="l_shoulder" type="hinge" axis="0 1 0" range="-1.5 1.5" damping="0.5"/>
        <geom type="capsule" fromto="0 0 0 -0.25 0 0" size="0.035 0.05" mass="1" material="body"/>
        <body pos="-0.25 0 0">
          <joint name="l_elbow" type="hinge" axis="0 1 0" range="-1.5 0" damping="0.3"/>
          <geom type="capsule" fromto="0 0 0 -0.2 0 0" size="0.03 0.04" mass="0.8" material="body"/>
        </body>
      </body>

      <!-- 右臂 -->
      <body name="r_shoulder" pos="0.12 0 0">
        <joint name="r_shoulder" type="hinge" axis="0 1 0" range="-1.5 1.5" damping="0.5"/>
        <geom type="capsule" fromto="0 0 0 0.25 0 0" size="0.035 0.05" mass="1" material="body"/>
        <body pos="0.25 0 0">
          <joint name="r_elbow" type="hinge" axis="0 1 0" range="-1.5 0" damping="0.3"/>
          <geom type="capsule" fromto="0 0 0 0.2 0 0" size="0.03 0.04" mass="0.8" material="body"/>
        </body>
      </body>

      <!-- 左腿 -->
      <body name="l_hip" pos="-0.08 0 -0.15">
        <joint name="l_hip" type="hinge" axis="0 1 0" range="-1 1" damping="1"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.3" size="0.05 0.08" mass="2.5" material="body"/>
        <body pos="0 0 -0.3">
          <joint name="l_knee" type="hinge" axis="0 1 0" range="0 2" damping="1"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.3" size="0.045 0.07" mass="2" material="body"/>
          <body pos="0 0 -0.3">
            <joint name="l_ankle" type="hinge" axis="0 1 0" range="-0.5 0.5" damping="0.5"/>
            <geom type="box" size="0.08 0.05 0.02" mass="0.5" material="body" friction="3"/>
          </body>
        </body>
      </body>

      <!-- 右腿 -->
      <body name="r_hip" pos="0.08 0 -0.15">
        <joint name="r_hip" type="hinge" axis="0 1 0" range="-1 1" damping="1"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.3" size="0.05 0.08" mass="2.5" material="body"/>
        <body pos="0 0 -0.3">
          <joint name="r_knee" type="hinge" axis="0 1 0" range="0 2" damping="1"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.3" size="0.045 0.07" mass="2" material="body"/>
          <body pos="0 0 -0.3">
            <joint name="r_ankle" type="hinge" axis="0 1 0" range="-0.5 0.5" damping="0.5"/>
            <geom type="box" size="0.08 0.05 0.02" mass="0.5" material="body" friction="3"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- 力矩控制执行器 -->
  <actuator>
    <motor joint="neck"        ctrllimited="true" ctrlrange="-20 20"        gear="100"/>
    <motor joint="l_shoulder"  ctrllimited="true" ctrlrange="-30 30"        gear="100"/>
    <motor joint="l_elbow"     ctrllimited="true" ctrlrange="-15 15"        gear="100"/>
    <motor joint="r_shoulder"  ctrllimited="true" ctrlrange="-30 30"        gear="100"/>
    <motor joint="r_elbow"      ctrllimited="true" ctrlrange="-15 15"        gear="100"/>
    <motor joint="l_hip"        ctrllimited="true" ctrlrange="-50 50"        gear="100"/>
    <motor joint="l_knee"       ctrllimited="true" ctrlrange="-50 50"        gear="100"/>
    <motor joint="l_ankle"      ctrllimited="true" ctrlrange="-30 30"        gear="100"/>
    <motor joint="r_hip"        ctrllimited="true" ctrlrange="-50 50"        gear="100"/>
    <motor joint="r_knee"       ctrllimited="true" ctrlrange="-50 50"        gear="100"/>
    <motor joint="r_ankle"      ctrllimited="true" ctrlrange="-30 30"        gear="100"/>
  </actuator>
</mujoco>
